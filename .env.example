# --- Joe agent runtime (local model) ---

# OpenAI-compatible chat endpoint for the Joe agent.
# Dev (Ollama on the Mac host):
JOE_LLM_BASE_URL=http://localhost:11434/v1
JOE_LLM_MODEL=qwen3:8b
JOE_LLM_API_KEY=ollama
# Prod (vLLM on a GPU VPC) — swap the three values above, no code change:
#   JOE_LLM_BASE_URL=http://vllm:8000/v1
#   JOE_LLM_MODEL=Qwen/Qwen3-8B
#   JOE_LLM_API_KEY=vllm

# --- Dormant pipelines (data / RAG utils / training). ---

# OpenAI-compatible API used by the RAG utilities and dataset generation.
# Leave OPENAI_BASE_URL empty to use OpenAI; point it at Ollama to run local:
#   OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL_ID=gpt-4o-mini
OPENAI_API_KEY=str
OPENAI_BASE_URL=

# Huggingface API Config
HUGGINGFACE_ACCESS_TOKEN=str

# Comet ML (during training)
COMET_API_KEY=str

# --- Required settings when deploying the code. ---
# --- Otherwise, default values work fine. ---

# MongoDB database
DATABASE_HOST="mongodb://llm_engineering:llm_engineering@127.0.0.1:27017"

# Qdrant vector database
USE_QDRANT_CLOUD=false
QDRANT_CLOUD_URL=str
QDRANT_APIKEY=str

# AWS Authentication (dormant training / evaluation pipelines)
AWS_ARN_ROLE=str
AWS_REGION=eu-central-1
AWS_ACCESS_KEY=str
AWS_SECRET_KEY=str
